<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>ru.kazantsev.nsmp.sdk.intellij_plugin</id>
    <name>NSMP SDK</name>
    <vendor email="exeki@yandex.ru">Kazantsev Egor</vendor>
    <description><![CDATA[
        Плагин поднимает локальный HTTP-сервис и готовит основу для интеграции IntelliJ IDEA с внешними инструментами.
    ]]></description>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="NSMP SDK Notifications" displayType="BALLOON" isLogByDefault="true"/>
        <postStartupActivity implementation="ru.kazantsev.nsmp.sdk.intellij_plugin.startup.NsdProjectStartupActivity"/>
        <editorNotificationProvider
                implementation="ru.kazantsev.nsmp.sdk.intellij_plugin.ui.notifications.GroovySyncEditorNotificationProvider"/>
        <toolWindow id="NSMP SDK"
                    anchor="right"
                    factoryClass="ru.kazantsev.nsmp.sdk.intellij_plugin.ui.ToolWindowFactory"
                    canCloseContents="false"/>
        <projectConfigurable id="ru.kazantsev.nsmp.sdk.intellij_plugin.services.settings"
                             parentId="tools"
                             instance="ru.kazantsev.nsmp.sdk.intellij_plugin.ui.PluginConfigurable"
                             displayName="NSMP SDK"/>
    </extensions>

</idea-plugin>
